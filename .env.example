# ===========================================
# Python 多功能智能助手 - 环境变量模板
# 复制此文件为 .env 并填入实际值
# ===========================================

# 运行环境: development | production | testing
FLASK_ENV=development

# 安全密钥（生产环境请使用随机字符串）
SECRET_KEY=change-this-to-a-random-string
JWT_SECRET_KEY=change-this-to-another-random-string

# 数据库 (默认 SQLite，生产环境改为 PostgreSQL 连接串)
# PostgreSQL 示例: postgresql://user:password@localhost:5432/assistant
DATABASE_URL=sqlite:///app.db

# ===========================================
# 大模型 API 密钥（至少配置一个）
# ===========================================

# Claude API (Anthropic) - 推荐
ANTHROPIC_API_KEY=sk-ant-your-key-here

# DeepSeek API - 备用
DEEPSEEK_API_KEY=your-deepseek-key-here

# 默认使用的模型: claude | deepseek
DEFAULT_MODEL=claude
